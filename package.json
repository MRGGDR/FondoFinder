{
  "name": "fondosfinder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -r ./scripts/readlink-eisdir-workaround.cjs ./node_modules/next/dist/bin/next dev",
    "build": "node -r ./scripts/readlink-eisdir-workaround.cjs ./node_modules/next/dist/bin/next build",
