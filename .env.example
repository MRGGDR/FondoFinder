NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Requerido para escrituras server-side (bypass RLS en route handlers).
# Obtener en: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Admin ligero (validacion server-side unicamente).
# En local, si mantienes el flujo historico, usa: ADMIN_ACCESS_CODE=admin.ungrd
ADMIN_ACCESS_CODE=
